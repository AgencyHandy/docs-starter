  "keyFeatures": [
    "Client portal with branded custom domain and white-labeling",
    "CRM with Kanban-based lead management and client profiles",
    "Service catalog with multiple packages, pricing tiers, and default task automation",
    "Order management with task tracking, file feedback, and client approval",
    "Proposal creation and sending with accept/reject workflow",
    "Invoicing and subscription billing with Stripe, PayPal, and other payment methods",
    "Team management with role-based permissions",
    "Support ticket system for client inquiries",
    "Timesheet and time tracking per task",
    "Intake and order forms for structured client onboarding",
    "Webhook management for real-time event automation",
    "REST API for creating leads, clients, and updating orders"
  ],
  "publicApiSurface": [
    "GET /accounts/companies — list companies associated with an API key",
    "POST /leads — create a new lead",
    "POST /clients — create a new client",
    "PATCH /orders/:id — update an existing order",
    "Webhooks: Lead.Created, Lead.Updated, Lead.Deleted",
    "API Key generation via Workspace Config → API Key tab"
  ]
}
